{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "identity",
	"compatibility_date": "2026-06-25",
	"pages_build_output_dir": ".svelte-kit/cloudflare",
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "identity",
			"database_id": "replace-with-cloudflare-d1-database-id"
		}
	]
}
